# Instagram watcher (single profile, backward-compatible)
IG_PROFILE_URL=https://www.instagram.com/somostitanes/
THREADS_PROFILE_URL=https://www.threads.net/@somostitanes

# Instagram watcher (multi profile, CSV)
# IG_PROFILE_URLS=https://www.instagram.com/somostitanes/,https://www.instagram.com/memesfan10/
# THREADS_PROFILE_URLS=https://www.threads.net/@somostitanes,https://www.threads.net/@memesfan10

ENABLE_THREADS_FALLBACK=true
IG_USE_AUTH_SESSION=false
PLAYWRIGHT_STORAGE_STATE_PATH=./data/instagram-storage-state.json
# Para nube (opcional): pega aquí el storageState exportado en base64.
# PLAYWRIGHT_STORAGE_STATE_B64=
PLAYWRIGHT_DISABLE_SANDBOX=true
POLL_MINUTES=30
DATA_DIR=./data
# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://your-public-r2-base-url/
R2_REGION=auto

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL_TEXT=gemini-2.5-pro
GEMINI_MODEL_IMAGE=gemini-2.0-flash-preview-image-generation

# Facebook Page publish
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
FB_GRAPH_VERSION=v25.0

# Runtime hardening (optional)
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=15000
REQUEST_TIMEOUT_MS=30000
PLAYWRIGHT_HEADLESS=true
