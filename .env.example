# Instagram watcher
IG_PROFILE_URL=https://www.instagram.com/somostitanes/
THREADS_PROFILE_URL=
ENABLE_THREADS_FALLBACK=true
POLL_MINUTES=5
DATA_DIR=./data
THREADS_PROFILE_UR=https://www.threads.com/@somostitanes
# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://your-public-r2-base-url/
R2_REGION=auto

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL_TEXT=gemini-1.5-pro
GEMINI_MODEL_IMAGE=gemini-2.0-flash-preview-image-generation

# Facebook Page publish
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
FB_GRAPH_VERSION=v25.0

# Runtime hardening (optional)
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=15000
REQUEST_TIMEOUT_MS=30000
PLAYWRIGHT_HEADLESS=true
