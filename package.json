{
  "name": "ig-to-facebook-viral-pipeline",
  "version": "1.0.0",
  "private": true,
  "description": "Pipeline de producción para vigilar Instagram público, generar copy/imagen viral con Gemini y publicar en Facebook Page",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pm2:start": "mkdir -p data/logs && npm run build && pm2 start ecosystem.config.cjs --env production --update-env",
    "pm2:restart": "pm2 restart ig-to-facebook-viral-pipeline --update-env",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production --update-env",
    "pm2:stop": "pm2 stop ig-to-facebook-viral-pipeline",
    "pm2:delete": "pm2 delete ig-to-facebook-viral-pipeline",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs ig-to-facebook-viral-pipeline",
    "pm2:save": "pm2 save",
    "playwright:install": "playwright install chromium",
    "playwright:install:deps": "playwright install --with-deps chromium",
    "ig:login": "tsx src/scripts/instagramLogin.ts",
    "ig:export-session": "tsx src/scripts/exportInstagramSession.ts",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.744.0",
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "node-cron": "^4.0.5",
    "playwright": "^1.52.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
